{
  "info": {
    "name": "CotizadorVBO API",
    "description": "Colección de endpoints para CotizadorVBO Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"vendedor\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.token) {",
                  "    pm.collectionVariables.set('token', response.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@virtualbackoffice.cl\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/auth/profile"
          }
        }
      ]
    },
    {
      "name": "Quotations",
      "item": [
        {
          "name": "Create Quotation",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{baseUrl}}/quotations",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientId\": \"uuid-del-cliente\",\n  \"issueDate\": \"2024-03-24\",\n  \"expirationDate\": \"2024-04-24\",\n  \"currency\": \"CLP\",\n  \"ivaPercentage\": 19,\n  \"validity\": \"30 DÍAS\",\n  \"paymentTerms\": \"50% anticipo, 50% contra entrega\",\n  \"executionTime\": \"60 días\",\n  \"items\": [\n    {\n      \"code\": \"VBO-ID\",\n      \"description\": \"Diseño de Identidad Visual\",\n      \"quantity\": 1,\n      \"quantityLabel\": \"1\",\n      \"unitPrice\": 15000,\n      \"subtotal\": 15000\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "List Quotations",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/quotations?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["quotations"],
              "query": [
                {"key": "page", "value": "1"},
                {"key": "limit", "value": "10"}
              ]
            }
          }
        },
        {
          "name": "Get Quotation by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/quotations/:id"
          }
        },
        {
          "name": "Send Quotation Email",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{baseUrl}}/quotations/:id/send-email",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"recipientEmail\": \"cliente@example.com\",\n  \"message\": \"Adjuntamos la cotización solicitada\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "Create Client",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "url": "{{baseUrl}}/clients",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Empresa XYZ\",\n  \"contactPerson\": \"Juan Pérez\",\n  \"email\": \"contacto@empresa.com\",\n  \"phone\": \"+56 9 1234 5678\",\n  \"address\": \"Dirección completa\",\n  \"taxId\": \"76.123.456-7\"\n}"
            }
          }
        },
        {
          "name": "List Clients",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/clients"
          }
        }
      ]
    },
    {
      "name": "Services",
      "item": [
        {
          "name": "List Services",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/services"
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Dashboard",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/reports/dashboard"
          }
        },
        {
          "name": "Quotations by Period",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/reports/quotations-by-period?startDate=2024-01-01&endDate=2024-12-31&groupBy=month",
              "host": ["{{baseUrl}}"],
              "path": ["reports", "quotations-by-period"],
              "query": [
                {"key": "startDate", "value": "2024-01-01"},
                {"key": "endDate", "value": "2024-12-31"},
                {"key": "groupBy", "value": "month"}
              ]
            }
          }
        }
      ]
    }
  ]
}
